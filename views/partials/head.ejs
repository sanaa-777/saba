<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | <%= settings.site_name || 'وكالة سبأ للأنباء' %></title>
  <meta name="description" content="<%= typeof article !== 'undefined' && article ? article.meta_description || article.summary : settings.site_description || 'وكالة الأنباء اليمنية سبأ' %>">
  <meta name="keywords" content="<%= settings.site_keywords || 'سبأ, أخبار, اليمن' %>">
  <meta name="author" content="<%= settings.site_name || 'وكالة سبأ للأنباء' %>">
  <% if (typeof article !== 'undefined' && article) { %>
  <meta property="og:title" content="<%= article.title %>">
  <meta property="og:description" content="<%= article.summary %>">
  <meta property="og:image" content="<%= article.image %>">
  <meta property="og:type" content="article">
  <meta property="og:url" content="<%= currentPath %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= article.title %>">
  <meta name="twitter:description" content="<%= article.summary %>">
  <meta name="twitter:image" content="<%= article.image %>">
  <% } else { %>
  <meta property="og:title" content="<%= title %> | <%= settings.site_name || 'وكالة سبأ للأنباء' %>">
  <meta property="og:description" content="<%= settings.site_description || 'وكالة الأنباء اليمنية سبأ' %>">
  <meta property="og:type" content="website">
  <% } %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <link rel="stylesheet" href="/css/slider.css">
  <script src="/socket.io/socket.io.js"></script>
  <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#1a237e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "NewsMediaOrganization",
    "name": "<%= settings.site_name || 'وكالة سبأ للأنباء' %>",
    "url": "/",
    "logo": "<%= settings.site_logo || '/images/logo.png' %>",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "<%= settings.contact_phone || '' %>",
      "contactType": "customer service"
    }
  }
  </script>
  <% if (typeof article !== 'undefined' && article) { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": "<%= article.title %>",
    "description": "<%= article.summary %>",
    "image": "<%= article.image %>",
    "datePublished": "<%= article.published_at %>",
    "dateModified": "<%= article.updated_at %>",
    "author": {
      "@type": "Organization",
      "name": "<%= settings.site_name || 'وكالة سبأ للأنباء' %>"
    },
    "publisher": {
      "@type": "Organization",
      "name": "<%= settings.site_name || 'وكالة سبأ للأنباء' %>",
      "logo": {
        "@type": "ImageObject",
        "url": "<%= settings.site_logo || '/images/logo.png' %>"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "/news/<%= article.id %>"
    }
  }
  </script>
  <% } %>
</head>
<body>
