<aside class="sidebar">
  <!-- Latest News Tabs -->
  <div class="sidebar-widget">
    <div class="widget-tabs">
      <button class="tab-btn active" data-tab="latest">الأحدث</button>
      <button class="tab-btn" data-tab="most-read">الأكثر قراءة</button>
    </div>
    <div class="tab-content active" id="tab-latest">
      <ul class="sidebar-news-list">
        <% if (typeof latestNews !== 'undefined') { %>
          <% latestNews.slice(0, 10).forEach((item, i) => { %>
            <li>
              <span class="news-number"><%= i + 1 %></span>
              <div class="news-info">
                <a href="/news/<%= item.id %>"><%= item.title %></a>
                <span class="news-date"><%= new Date(item.published_at).toLocaleDateString('ar-YE') %></span>
              </div>
            </li>
          <% }); %>
        <% } %>
      </ul>
    </div>
    <div class="tab-content" id="tab-most-read">
      <ul class="sidebar-news-list">
        <% if (typeof latestNews !== 'undefined') { %>
          <% latestNews.sort((a, b) => b.views - a.views).slice(0, 10).forEach((item, i) => { %>
            <li>
              <span class="news-number"><%= i + 1 %></span>
              <div class="news-info">
                <a href="/news/<%= item.id %>"><%= item.title %></a>
                <span class="news-date"><%= item.views %> مشاهدة</span>
              </div>
            </li>
          <% }); %>
        <% } %>
      </ul>
    </div>
  </div>

  <!-- Social Media Widget -->
  <div class="sidebar-widget">
    <h3 class="widget-title">تابعنا</h3>
    <div class="social-follow">
      <a href="<%= settings.facebook || '#' %>" target="_blank" class="social-btn facebook">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        فيسبوك
      </a>
      <a href="<%= settings.twitter || '#' %>" target="_blank" class="social-btn twitter">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        تويتر
      </a>
      <a href="<%= settings.telegram || '#' %>" target="_blank" class="social-btn telegram">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        تلغرام
      </a>
      <a href="<%= settings.youtube || '#' %>" target="_blank" class="social-btn youtube">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        يوتيوب
      </a>
    </div>
  </div>

  <!-- Newsletter Widget -->
  <div class="sidebar-widget newsletter-widget">
    <h3 class="widget-title">النشرة البريدية</h3>
    <p>اشترك في نشرتنا البريدية لتصلك آخر الأخبار</p>
    <form class="newsletter-form">
      <input type="email" placeholder="بريدك الإلكتروني" required>
      <button type="submit">اشترك</button>
    </form>
  </div>
</aside>
