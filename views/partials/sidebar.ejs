<aside class="sidebar">
  <%
  function timeAgo(dateStr) {
    if (!dateStr) return '';
    const now = new Date();
    const date = new Date(dateStr);
    const diff = Math.floor((now - date) / 1000);
    if (diff < 60) return 'الآن';
    if (diff < 3600) return 'قبل ' + Math.floor(diff / 60) + ' دقيقة';
    if (diff < 86400) return 'قبل ' + Math.floor(diff / 3600) + ' ساعة';
    if (diff < 172800) return 'قبل يوم';
    if (diff < 604800) return 'قبل ' + Math.floor(diff / 86400) + ' أيام';
    return date.toLocaleDateString('ar-YE');
  }
  %>
  <% const latestItems = (typeof latestNews !== 'undefined' && latestNews) ? latestNews : []; %>
  <% const pollData = typeof activePoll !== 'undefined' ? activePoll : null; %>
  <% const pollOptions = typeof activePollOptions !== 'undefined' && activePollOptions ? activePollOptions : []; %>
  <% const pollVotesTotal = typeof activePollTotalVotes !== 'undefined' ? activePollTotalVotes : 0; %>

  <div class="sidebar-widget">
    <div class="widget-tabs">
      <button class="tab-btn active" data-tab="latest"><%= t('latest_news') %></button>
      <button class="tab-btn" data-tab="most-read"><%= t('most_read') %></button>
    </div>

    <div class="tab-content active" id="tab-latest">
      <ul class="sidebar-news-list">
        <% if (latestItems.length) { %>
          <% latestItems.slice(0, 8).forEach((item, index) => { %>
            <li>
              <span class="news-number"><%= index + 1 %></span>
              <div class="news-info">
                <a href="/news/<%= item.id %>"><%= item.title %></a>
                <span class="news-date"><%= timeAgo(item.published_at) %></span>
              </div>
            </li>
          <% }) %>
        <% } else { %>
          <li><div class="news-info"><span class="news-date">لا توجد بيانات حالياً</span></div></li>
        <% } %>
      </ul>
    </div>

    <div class="tab-content" id="tab-most-read">
      <ul class="sidebar-news-list">
        <% if (latestItems.length) { %>
          <% latestItems.slice().sort((a, b) => (b.views || 0) - (a.views || 0)).slice(0, 8).forEach((item, index) => { %>
            <li>
              <span class="news-number"><%= index + 1 %></span>
              <div class="news-info">
                <a href="/news/<%= item.id %>"><%= item.title %></a>
                <span class="news-date"><%= timeAgo(item.published_at) %></span>
              </div>
            </li>
          <% }) %>
        <% } else { %>
          <li><div class="news-info"><span class="news-date">لا توجد بيانات حالياً</span></div></li>
        <% } %>
      </ul>
    </div>
  </div>

  <% if (pollData) { %>
  <div class="sidebar-widget poll-widget">
    <h3 class="widget-title"><%= t('polls') %></h3>
    <div class="poll-question" id="pollWidget">
      <p class="poll-text"><%= pollData.question %></p>
      <div class="poll-options" id="pollOptions">
        <% pollOptions.forEach(option => { %>
          <div class="poll-option">
            <button class="poll-vote-btn" data-poll="<%= pollData.id %>" data-option="<%= option.id %>"><%= option.option_text %></button>
            <div class="poll-bar">
              <div class="poll-bar-fill" style="width:<%= pollVotesTotal > 0 ? Math.round((option.votes / pollVotesTotal) * 100) : 0 %>%"></div>
            </div>
            <span class="poll-percent"><%= pollVotesTotal > 0 ? Math.round((option.votes / pollVotesTotal) * 100) : 0 %>% (<%= option.votes %>)</span>
          </div>
        <% }) %>
      </div>
      <p class="poll-total"><%= t('total_votes') %>: <span id="pollTotalVotes"><%= pollVotesTotal %></span></p>
    </div>
  </div>
  <% } %>

  <div class="sidebar-widget">
    <h3 class="widget-title"><%= t('follow_us') %></h3>
    <div class="social-follow">
      <a href="<%= settings.facebook || '#' %>" target="_blank" rel="noopener" class="social-btn facebook">
        <span>فيسبوك</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13.5 21v-8h2.7l.4-3h-3.1V8.2c0-.9.3-1.5 1.5-1.5h1.7V4c-.3 0-1.3-.1-2.5-.1-2.4 0-4 1.5-4 4.2V10H7.5v3h2.6v8h3.4z"/></svg>
      </a>
      <a href="<%= settings.twitter || '#' %>" target="_blank" rel="noopener" class="social-btn twitter">
        <span>إكس</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 2H22l-6.8 7.8L23.2 22h-6.3l-4.9-6.4L6.3 22H3.2l7.3-8.4L1 2h6.5l4.4 5.8L18.9 2zm-1.1 18h1.7L6.6 3.9H4.8L17.8 20z"/></svg>
      </a>
      <a href="<%= settings.telegram || '#' %>" target="_blank" rel="noopener" class="social-btn telegram">
        <span>تيليجرام</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9.8 15.6 9.4 21c.6 0 .9-.3 1.3-.6l3-2.9 6.1 4.5c1.1.6 1.8.3 2.1-1l3.8-17.7h0c.4-1.8-.6-2.5-1.7-2.1L1.8 9.5c-1.7.7-1.7 1.7-.3 2.1l5.7 1.8L20.4 5c.6-.4 1.2-.2.7.2"/></svg>
      </a>
      <a href="<%= settings.youtube || '#' %>" target="_blank" rel="noopener" class="social-btn youtube">
        <span>يوتيوب</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.7 15.5V8.5L15.8 12l-6.1 3.5z"/></svg>
      </a>
    </div>
  </div>

  <div class="sidebar-widget newsletter-widget">
    <h3 class="widget-title"><%= t('newsletter') %></h3>
    <p><%= t('newsletter_desc') %></p>
    <form class="newsletter-form" id="newsletterForm">
      <input type="email" name="email" placeholder="<%= t('email') %>" required>
      <button type="submit" class="btn btn-primary"><%= t('subscribe') %></button>
    </form>
    <div class="newsletter-message" id="newsletterMessage" style="display:none;"></div>
  </div>
</aside>
