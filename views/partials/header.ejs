<!-- Top Bar -->
<div class="top-bar">
  <div class="container">
    <div class="top-bar-right">
      <span class="date-gregorian"></span>
      <span class="date-separator">|</span>
      <span class="date-hijri"></span>
    </div>
    <div class="top-bar-left">
      <a href="<%= settings.facebook || '#' %>" target="_blank" class="social-icon" aria-label="Facebook">FB</a>
      <a href="<%= settings.twitter || '#' %>" target="_blank" class="social-icon" aria-label="Twitter">X</a>
      <a href="<%= settings.youtube || '#' %>" target="_blank" class="social-icon" aria-label="YouTube">YT</a>
      <a href="<%= settings.telegram || '#' %>" target="_blank" class="social-icon" aria-label="Telegram">TG</a>
      <a href="/rss" class="social-icon" aria-label="RSS">RSS</a>
    </div>
  </div>
</div>

<!-- Site Header -->
<header class="site-header">
  <div class="container">
    <div class="header-inner">
      <!-- Mobile Menu Toggle -->
      <button class="mobile-menu-toggle" id="mobileMenuBtn" aria-label="القائمة">
        <span></span><span></span><span></span>
      </button>
      
      <div class="logo">
        <a href="/">
          <img src="/images/logo.png" alt="أوتر" class="logo-img" width="50" height="50">
          <div class="logo-text">
            <h1>أوتر</h1>
            <span>Awtar</span>
          </div>
        </a>
      </div>
      
      <div class="header-search">
        <form action="/search" method="GET">
          <input type="text" name="q" placeholder="<%= t('search_placeholder') %>" aria-label="<%= t('search') %>">
          <button type="submit" aria-label="<%= t('search') %>">🔍</button>
        </form>
      </div>
      
      <!-- Language Switcher -->
      <div class="lang-switcher" id="langSwitcher">
        <button class="lang-btn" id="langToggle" aria-label="تغيير اللغة">
          🌐 <span><%= lang.toUpperCase() %></span> ▾
        </button>
        <div class="lang-dropdown" id="langDropdown">
          <a href="?lang=ar" class="<%= lang === 'ar' ? 'active' : '' %>">🇸🇦 العربية</a>
          <a href="?lang=en" class="<%= lang === 'en' ? 'active' : '' %>">🇬🇧 English</a>
          <a href="?lang=fr" class="<%= lang === 'fr' ? 'active' : '' %>">🇫🇷 Français</a>
          <a href="?lang=es" class="<%= lang === 'es' ? 'active' : '' %>">🇪🇸 Español</a>
          <a href="?lang=de" class="<%= lang === 'de' ? 'active' : '' %>">🇩🇪 Deutsch</a>
          <a href="?lang=fa" class="<%= lang === 'fa' ? 'active' : '' %>">🇮🇷 فارسی</a>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Main Navigation -->
<nav class="main-nav" id="mainNav">
  <div class="container">
    <ul class="nav-list">
      <li class="nav-item"><a href="/" class="nav-link active">الرئيسية</a></li>
      <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
        <% categories.slice(0, 10).forEach(cat => { %>
          <li class="nav-item">
            <a href="/category/<%= cat.id %>" class="nav-link"><%= cat.name_ar %></a>
          </li>
        <% }); %>
      <% } %>
      <li class="nav-item nav-dropdown">
        <a href="#" class="nav-link">المزيد ▾</a>
        <ul class="nav-dropdown-menu">
          <li><a href="/videos">📹 فيديو</a></li>
          <li><a href="/galleries">🖼️ صور</a></li>
          <li><a href="/audios">🎧 صوتيات</a></li>
          <li><a href="/caricatures">✏️ كاريكاتير</a></li>
          <li><a href="/publications">📄 منشورات</a></li>
          <li><a href="/files">📁 ملفات</a></li>
          <li><a href="/services">🆓 خدمات مجانية</a></li>
          <li><a href="/subscribe">📧 اشتراك</a></li>
        </ul>
      </li>
    </ul>
  </div>
</nav>

<!-- Mobile Navigation -->
<div class="mobile-nav" id="mobileNav">
  <div class="mobile-nav-header">
    <div class="mobile-nav-logo">أوتر</div>
    <button class="mobile-nav-close" id="mobileNavClose" aria-label="إغلاق">✕</button>
  </div>
  <div class="mobile-nav-search">
    <form action="/search" method="GET">
      <input type="text" name="q" placeholder="ابحث...">
      <button type="submit">🔍</button>
    </form>
  </div>
  <ul class="mobile-nav-list">
    <li><a href="/">🏠 الرئيسية</a></li>
    <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
      <% categories.forEach(cat => { %>
        <li><a href="/category/<%= cat.id %>"><%= cat.name_ar %></a></li>
      <% }); %>
    <% } %>
    <li class="mobile-nav-divider"></li>
    <li><a href="/videos">📹 فيديو</a></li>
    <li><a href="/galleries">🖼️ صور</a></li>
    <li><a href="/audios">🎧 صوتيات</a></li>
    <li><a href="/caricatures">✏️ كاريكاتير</a></li>
    <li><a href="/publications">📄 منشورات</a></li>
    <li><a href="/files">📁 ملفات</a></li>
    <li><a href="/services">🆓 خدمات مجانية</a></li>
    <li><a href="/subscribe">📧 اشتراك</a></li>
    <li class="mobile-nav-divider"></li>
    <li><a href="/about">ℹ️ من نحن</a></li>
    <li><a href="/contact">📬 اتصل بنا</a></li>
  </ul>
  <div class="mobile-nav-lang">
    <a href="?lang=ar" class="<%= lang === 'ar' ? 'active' : '' %>">🇸🇦 عربي</a>
    <a href="?lang=en" class="<%= lang === 'en' ? 'active' : '' %>">🇬🇧 EN</a>
    <a href="?lang=fr" class="<%= lang === 'fr' ? 'active' : '' %>">🇫🇷 FR</a>
  </div>
</div>
<div class="mobile-nav-overlay" id="mobileNavOverlay"></div>
