<!-- Site Header -->
<header class="site-header">
  <div class="container">
    <div class="header-inner">
      <div class="logo">
        <a href="/">
          <div class="logo-text">
            <h1>وكالة سبأ للأنباء</h1>
            <span>SABA News Agency</span>
          </div>
        </a>
      </div>
      <div class="header-search">
        <form action="/search" method="GET">
          <input type="text" name="q" placeholder="<%= t('search_placeholder') %>" aria-label="<%= t('search') %>">
          <button type="submit" aria-label="<%= t('search') %>">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </button>
        </form>
      </div>
      <!-- Language Switcher -->
      <div class="lang-switcher">
        <button class="lang-btn" id="langToggle">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <span><%= lang.toUpperCase() %></span>
        </button>
        <div class="lang-dropdown" id="langDropdown">
          <a href="?lang=ar" class="<%= lang === 'ar' ? 'active' : '' %>">🇸🇦 العربية</a>
          <a href="?lang=en" class="<%= lang === 'en' ? 'active' : '' %>">🇬🇧 English</a>
          <a href="?lang=fr" class="<%= lang === 'fr' ? 'active' : '' %>">🇫🇷 Français</a>
          <a href="?lang=es" class="<%= lang === 'es' ? 'active' : '' %>">🇪🇸 Español</a>
          <a href="?lang=de" class="<%= lang === 'de' ? 'active' : '' %>">🇩🇪 Deutsch</a>
          <a href="?lang=fa" class="<%= lang === 'fa' ? 'active' : '' %>">🇮🇷 فارسی</a>
        </div>
      </div>
      <button class="mobile-menu-toggle" aria-label="<%= t('home') %>">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<!-- Main Navigation -->
<nav class="main-nav" id="mainNav">
  <div class="container">
    <ul class="nav-list">
      <li class="nav-item"><a href="/" class="nav-link">الرئيسية</a></li>
      <% if (typeof categories !== 'undefined') { %>
        <% categories.forEach(cat => { %>
          <li class="nav-item">
            <a href="/category/<%= cat.id %>" class="nav-link"><%= cat.name_ar %></a>
          </li>
        <% }); %>
      <% } %>
      <li class="nav-item"><a href="/videos" class="nav-link">فيديو</a></li>
      <li class="nav-item"><a href="/galleries" class="nav-link">صور</a></li>
      <li class="nav-item"><a href="/audios" class="nav-link">صوتيات</a></li>
      <li class="nav-item"><a href="/caricatures" class="nav-link">كاريكاتير</a></li>
      <li class="nav-item"><a href="/publications" class="nav-link">منشورات</a></li>
      <li class="nav-item"><a href="/files" class="nav-link">ملفات</a></li>
      <li class="nav-item"><a href="/services" class="nav-link">خدمات مجانية</a></li>
      <li class="nav-item"><a href="/subscribe" class="nav-link">اشتراك</a></li>
    </ul>
  </div>
</nav>

<!-- Mobile Navigation -->
<div class="mobile-nav" id="mobileNav">
  <div class="mobile-nav-header">
    <span>القائمة</span>
    <button class="mobile-nav-close" aria-label="إغلاق">&times;</button>
  </div>
  <ul class="mobile-nav-list">
    <li><a href="/">الرئيسية</a></li>
    <% if (typeof categories !== 'undefined') { %>
      <% categories.forEach(cat => { %>
        <li><a href="/category/<%= cat.id %>"><%= cat.name_ar %></a></li>
      <% }); %>
    <% } %>
    <li><a href="/videos">فيديو</a></li>
    <li><a href="/galleries">صور</a></li>
    <li><a href="/audios">صوتيات</a></li>
    <li><a href="/caricatures">كاريكاتير</a></li>
    <li><a href="/publications">منشورات</a></li>
    <li><a href="/files">ملفات</a></li>
    <li><a href="/services">خدمات مجانية</a></li>
    <li><a href="/subscribe">اشتراك</a></li>
    <li><a href="/search">بحث</a></li>
  </ul>
</div>
<div class="mobile-nav-overlay" id="mobileNavOverlay"></div>
