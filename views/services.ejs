<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">الخدمات المجانية</span>
    </nav>
    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header" style="border-color: #2e7d32;">
            <h2 style="color: #2e7d32;">🆓 الخدمات المجانية</h2>
          </div>
          <div style="padding: 20px;">
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">
              
              <div style="background: linear-gradient(135deg, #e8f5e9, #c8e6c9); padding: 25px; border-radius: 12px; border-right: 4px solid #2e7d32;">
                <h3 style="color: #2e7d32; margin-bottom: 10px;">📰 خدمة RSS المجانية</h3>
                <p style="font-size: 14px; color: #555; line-height: 1.7;">احصل على آخر الأخبار مباشرة عبر خدمة RSS_feed. يمكنك إضافة رابط التغذية إلى قارئ الأخبار المفضل لديك.</p>
                <a href="/rss" style="display: inline-block; margin-top: 10px; padding: 8px 16px; background: #2e7d32; color: #fff; border-radius: 6px; font-size: 13px;">اشترك الآن</a>
              </div>

              <div style="background: linear-gradient(135deg, #e3f2fd, #bbdefb); padding: 25px; border-radius: 12px; border-right: 4px solid #1565c0;">
                <h3 style="color: #1565c0; margin-bottom: 10px;">📧 النشرة البريدية</h3>
                <p style="font-size: 14px; color: #555; line-height: 1.7;">اشترك في النشرة البريدية ليصلك ملخص يومي لأهم الأخبار مباشرة إلى بريدك الإلكتروني.</p>
                <a href="#newsletter" style="display: inline-block; margin-top: 10px; padding: 8px 16px; background: #1565c0; color: #fff; border-radius: 6px; font-size: 13px;">اشترك</a>
              </div>

              <div style="background: linear-gradient(135deg, #fce4ec, #f8bbd0); padding: 25px; border-radius: 12px; border-right: 4px solid #c62828;">
                <h3 style="color: #c62828; margin-bottom: 10px;">🔔 الإشعارات الفورية</h3>
                <p style="font-size: 14px; color: #555; line-height: 1.7;">فعّل الإشعارات الفورية لتصلك آخر الأخبار العاجلة فور نشرها على الموقع.</p>
                <button onclick="if('Notification' in window)Notification.requestPermission()" style="margin-top: 10px; padding: 8px 16px; background: #c62828; color: #fff; border: none; border-radius: 6px; font-size: 13px; cursor: pointer;">تفعيل الإشعارات</button>
              </div>

              <div style="background: linear-gradient(135deg, #fff3e0, #ffe0b2); padding: 25px; border-radius: 12px; border-right: 4px solid #e65100;">
                <h3 style="color: #e65100; margin-bottom: 10px;">📱 تطبيق PWA</h3>
                <p style="font-size: 14px; color: #555; line-height: 1.7;">أضف الموقع إلى شاشتك الرئيسية كتطبيق مستقل يعمل بدون إنترنت.</p>
                <button onclick="if(window.deferredPrompt)window.deferredPrompt.prompt()" style="margin-top: 10px; padding: 8px 16px; background: #e65100; color: #fff; border: none; border-radius: 6px; font-size: 13px; cursor: pointer;">تثبيت التطبيق</button>
              </div>

              <div style="background: linear-gradient(135deg, #f3e5f5, #e1bee7); padding: 25px; border-radius: 12px; border-right: 4px solid #6a1b9a;">
                <h3 style="color: #6a1b9a; margin-bottom: 10px;">🔍 البحث المتقدم</h3>
                <p style="font-size: 14px; color: #555; line-height: 1.7;">ابحث في أرشيف الأخبار باستخدام كلمات مفتاحية، تصنيفات، وتواريخ محددة.</p>
                <a href="/search" style="display: inline-block; margin-top: 10px; padding: 8px 16px; background: #6a1b9a; color: #fff; border-radius: 6px; font-size: 13px;">ابحث الآن</a>
              </div>

              <div style="background: linear-gradient(135deg, #e0f2f1, #b2dfdb); padding: 25px; border-radius: 12px; border-right: 4px solid #00695c;">
                <h3 style="color: #00695c; margin-bottom: 10px;">📋 خريطة الموقع</h3>
                <p style="font-size: 14px; color: #555; line-height: 1.7;">تصفح خريطة الموقع للوصول السريع إلى جميع الصفحات والأقسام.</p>
                <a href="/sitemap.xml" style="display: inline-block; margin-top: 10px; padding: 8px 16px; background: #00695c; color: #fff; border-radius: 6px; font-size: 13px;">عرض الخريطة</a>
              </div>

            </div>
          </div>
        </section>
      </div>
      <%- include('partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
