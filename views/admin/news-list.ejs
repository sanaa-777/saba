<%- include('header') %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <h3>إدارة الأخبار</h3>
      <p class="admin-card-subtitle">عرض منظم للأرشيف التحريري مع فلاتر سريعة وإجراءات مباشرة.</p>
    </div>
    <a href="/admin/news/create" class="btn btn-primary">إضافة خبر</a>
  </div>
  <div class="filters-bar">
    <select onchange="window.location.href='?status='+this.value+'&category=<%= filters.category || '' %>'">
      <option value="">جميع الحالات</option>
      <option value="1" <% if (filters.status === '1') { %>selected<% } %>>منشور</option>
      <option value="0" <% if (filters.status === '0') { %>selected<% } %>>مسودة</option>
    </select>
    <select onchange="window.location.href='?category='+this.value+'&status=<%= filters.status || '' %>'">
      <option value="">جميع التصنيفات</option>
      <% categories.forEach(function(cat) { %>
        <option value="<%= cat.id %>" <% if (String(filters.category) === String(cat.id)) { %>selected<% } %>><%= cat.name_ar %></option>
      <% }); %>
    </select>
    <span class="filters-summary"><%= pagination.total %> خبر</span>
  </div>
  <div class="admin-card-body" style="padding:0;">
    <div class="table-wrapper">
      <table class="admin-table">
        <thead>
          <tr>
            <th>#</th><th>صورة</th><th>العنوان</th><th>التصنيف</th><th>عاجل</th><th>الحالة</th><th>المشاهدات</th><th>إجراءات</th>
          </tr>
        </thead>
        <tbody>
          <% news.forEach(function(item) { %>
          <tr id="news-row-<%= item.id %>">
            <td><%= item.id %></td>
            <td>
              <% if (item.image) { %>
                <img src="<%= item.image %>" class="thumb" loading="lazy" alt="<%= item.title %>">
              <% } else { %>
                <span class="muted-cell">—</span>
              <% } %>
            </td>
            <td><%= item.title.length > 48 ? item.title.substring(0, 48) + '…' : item.title %></td>
            <td><%= item.category_name || '-' %></td>
            <td><% if (item.is_breaking) { %><span class="badge badge-danger">عاجل</span><% } else { %><span class="muted-cell">—</span><% } %></td>
            <td><span class="badge <%= item.status === 1 ? 'badge-success' : 'badge-warning' %>"><%= item.status === 1 ? 'منشور' : 'مسودة' %></span></td>
            <td><%= item.views.toLocaleString() %></td>
            <td class="actions">
              <a href="/admin/news/edit/<%= item.id %>" class="btn btn-sm btn-primary">تعديل</a>
              <a href="/news/<%= item.id %>" class="btn btn-sm btn-secondary" target="_blank">عرض</a>
              <button class="btn btn-sm btn-danger" onclick="deleteNews(<%= item.id %>)">حذف</button>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <% if (pagination.totalPages > 1) { %>
  <div class="admin-pagination">
    <% if (pagination.page > 1) { %><a href="?page=<%= pagination.page - 1 %>&status=<%= filters.status || '' %>&category=<%= filters.category || '' %>">السابق</a><% } %>
    <% for (var i = Math.max(1, pagination.page - 2); i <= Math.min(pagination.totalPages, pagination.page + 2); i++) { %>
      <a href="?page=<%= i %>&status=<%= filters.status || '' %>&category=<%= filters.category || '' %>" <% if (i === pagination.page) { %>class="active"<% } %>><%= i %></a>
    <% } %>
    <% if (pagination.page < pagination.totalPages) { %><a href="?page=<%= pagination.page + 1 %>&status=<%= filters.status || '' %>&category=<%= filters.category || '' %>">التالي</a><% } %>
  </div>
  <% } %>
</div>

<script>
async function parseDeleteResponse(response) {
  const contentType = response.headers.get('content-type') || '';
  if (contentType.includes('application/json')) {
    return response.json();
  }
  const text = await response.text();
  return {
    success: false,
    message: text && text.trim() ? text.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim() : 'تعذر تفسير استجابة الخادم'
  };
}

async function deleteNews(id) {
  if (!confirm('هل أنت متأكد من حذف هذا الخبر؟')) return;
  try {
    const res = await fetch('/api/v1/admin/news/delete/' + id, {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Accept': 'application/json' }
    });
    const result = await parseDeleteResponse(res);
    if (res.ok && result.success) {
      const row = document.getElementById('news-row-' + id);
      if (row) {
        row.style.transition = 'opacity 0.3s';
        row.style.opacity = '0';
        setTimeout(() => row.remove(), 300);
      }
    } else {
      alert(result.message || 'تعذر حذف الخبر');
    }
  } catch (err) {
    alert('تعذر الاتصال بالخادم، يرجى المحاولة مرة أخرى');
  }
}
</script>

<%- include('footer') %>
