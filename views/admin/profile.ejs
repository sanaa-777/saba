<%- include('header') %>

<div class="admin-card">
  <div class="admin-card-header"><h3>الملف الشخصي</h3></div>
  <div class="admin-card-body">
    <% if (error) { %><div class="error-msg"><%= error %></div><% } %>
    <% if (success) { %><div class="success-msg"><%= success %></div><% } %>
    <form method="POST" action="/admin/profile">
      <div class="form-group"><label>الاسم</label><input type="text" name="name" value="<%= admin.name %>" required></div>
      <h4 style="margin:20px 0 15px;color:#1a237e;">تغيير كلمة المرور (اختياري)</h4>
      <div class="form-group"><label>كلمة المرور الحالية</label><input type="password" name="current_password"></div>
      <div class="form-group"><label>كلمة المرور الجديدة</label><input type="password" name="new_password"></div>
      <div class="form-actions"><button type="submit" class="btn btn-primary">تحديث</button></div>
    </form>
  </div>
</div>

<%- include('footer') %>
