<%- include('header') %>

<div class="admin-card">
  <div class="admin-card-header">
    <div>
      <h3><%= article ? 'تعديل خبر' : 'إضافة خبر جديد' %></h3>
      <p class="admin-card-subtitle">واجهة تحرير مصقولة تحافظ على الوظائف الحالية وتسهّل إدخال البيانات.</p>
    </div>
    <a href="/admin/news" class="btn btn-secondary">العودة</a>
  </div>
  <div class="admin-card-body">
    <div id="statusMsg" class="status-msg"></div>
    <form id="newsForm" method="POST" action="<%= article ? '/api/v1/admin/news/edit/' + article.id : '/api/v1/admin/news/create' %>" enctype="multipart/form-data">
      <div class="form-row">
        <div class="form-group">
          <label>العنوان *</label>
          <input type="text" name="title" value="<%= article ? article.title : '' %>" required>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>الملخص</label>
          <textarea name="summary" rows="3"><%= article ? article.summary : '' %></textarea>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>المحتوى *</label>
          <textarea name="content" rows="14" required><%= article ? article.content : '' %></textarea>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>التصنيف</label>
          <select name="category_id">
            <option value="">اختر التصنيف</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>" <%= article && article.category_id == cat.id ? 'selected' : '' %>><%= cat.name_ar %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-group">
          <label>المصدر</label>
          <input type="text" name="source" value="<%= article ? article.source || '' : 'أوتر' %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>الصورة الرئيسية</label>
          <input type="file" name="image" accept="image/*,video/*,audio/*" id="imageInput">
          <% if (article && article.image) { %>
            <div class="current-media-preview"><img src="<%= article.image %>" id="currentImage" alt="الصورة الحالية"></div>
            <label class="form-check"><input type="checkbox" name="keep_image" value="1" checked id="keepImage"> الاحتفاظ بالصورة الحالية</label>
          <% } %>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>الوسوم</label>
          <div class="tag-selection-grid">
            <% tags.forEach(tag => { %>
              <label class="form-check tag-check">
                <input type="checkbox" name="tags" value="<%= tag.id %>" <%= article && articleTags && articleTags.includes(tag.id) ? 'checked' : '' %>>
                <span><%= tag.name %></span>
              </label>
            <% }); %>
          </div>
        </div>
      </div>
      <div class="form-row feature-flags">
        <div class="form-group"><label class="form-check"><input type="checkbox" name="is_breaking" value="1" <%= article && article.is_breaking ? 'checked' : '' %>> خبر عاجل</label></div>
        <div class="form-group"><label class="form-check"><input type="checkbox" name="is_slider" value="1" <%= article && article.is_slider ? 'checked' : '' %>> إظهار في السلايدر</label></div>
        <div class="form-group"><label class="form-check"><input type="checkbox" name="is_featured" value="1" <%= article && article.is_featured ? 'checked' : '' %>> خبر مميز</label></div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>الحالة</label>
          <select name="status">
            <option value="1" <%= article && article.status === 1 ? 'selected' : '' %>>منشور</option>
            <option value="0" <%= article && article.status === 0 ? 'selected' : '' %>>مسودة</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>عنوان SEO</label>
          <input type="text" name="meta_title" value="<%= article ? article.meta_title || '' : '' %>">
        </div>
        <div class="form-group">
          <label>وصف SEO</label>
          <input type="text" name="meta_description" value="<%= article ? article.meta_description || '' : '' %>">
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary" id="submitBtn"><span id="btnText"><%= article ? 'حفظ التعديلات' : 'نشر الخبر' %></span><span id="btnSpinner" style="display:none"><span class="spinner"></span> جاري الحفظ...</span></button>
        <a href="/admin/news" class="btn btn-secondary">إلغاء</a>
      </div>
    </form>
  </div>
</div>

<script>
document.getElementById('newsForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('submitBtn');
  const btnText = document.getElementById('btnText');
  const btnSpinner = document.getElementById('btnSpinner');
  const statusMsg = document.getElementById('statusMsg');
  btn.disabled = true;
  btnText.style.display = 'none';
  btnSpinner.style.display = 'inline-flex';
  statusMsg.style.display = 'none';
  const formData = new FormData(this);
  try {
    const response = await fetch(this.action, { method: 'POST', body: formData, credentials: 'same-origin' });
    const result = await response.json();
    if (result.success) {
      statusMsg.className = 'status-msg success';
      statusMsg.textContent = result.message;
      statusMsg.style.display = 'flex';
      if (!this.action.includes('/edit/')) {
        setTimeout(() => { window.location.href = '/admin/news'; }, 1200);
      } else {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    } else {
      statusMsg.className = 'status-msg error';
      statusMsg.textContent = result.message || 'حدث خطأ';
      statusMsg.style.display = 'flex';
    }
  } catch (err) {
    statusMsg.className = 'status-msg error';
    statusMsg.textContent = 'خطأ في الاتصال: ' + err.message;
    statusMsg.style.display = 'flex';
  } finally {
    btn.disabled = false;
    btnText.style.display = 'inline';
    btnSpinner.style.display = 'none';
  }
});
</script>

<%- include('footer') %>
