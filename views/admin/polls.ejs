<%- include('header') %>

<div class="admin-card">
  <div class="admin-card-header">
    <h3>إدارة الاستطلاعات</h3>
    <button class="btn btn-primary" onclick="document.getElementById('addPoll').style.display='block'">+ استطلاع جديد</button>
  </div>
  <div class="admin-card-body">
    <div id="addPoll" style="display:none;margin-bottom:20px;padding:20px;background:#f9f9f9;border-radius:8px;">
      <form method="POST" action="/admin/polls/create">
        <div class="form-group"><label>السؤال</label><input type="text" name="question" required placeholder="اكتب سؤال الاستطلاع..."></div>
        <div class="form-group"><label>الخيارات (سطر لكل خيار)</label><textarea name="options" rows="4" required placeholder="الخيار الأول&#10;الخيار الثاني&#10;الخيار الثالث"></textarea></div>
        <button type="submit" class="btn btn-primary">إنشاء</button>
        <button type="button" class="btn btn-secondary" onclick="this.closest('#addPoll').style.display='none'">إلغاء</button>
      </form>
    </div>

    <% if (polls.length > 0) { %>
    <% polls.forEach(poll => { %>
    <div style="border:1px solid #eee;border-radius:8px;padding:15px;margin-bottom:15px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
        <h4 style="margin:0;"><%= poll.question %></h4>
        <div style="display:flex;gap:5px;align-items:center;">
          <% if (poll.is_active) { %><span class="badge badge-success">مفعل</span><% } else { %><span class="badge badge-warning">معطل</span><% } %>
          <span style="font-size:13px;color:#888;"><%= poll.total_votes || 0 %> صوت</span>
        </div>
      </div>
      <% poll.options.forEach(opt => { %>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:5px;">
        <span style="flex:1;font-size:14px;"><%= opt.option_text %></span>
        <span style="font-size:13px;color:#888;"><%= opt.votes %> صوت</span>
        <div style="width:100px;height:6px;background:#eee;border-radius:3px;overflow:hidden;">
          <div style="height:100%;background:#1a237e;border-radius:3px;width:<%= poll.total_votes > 0 ? Math.round(opt.votes / poll.total_votes * 100) : 0 %>%"></div>
        </div>
        <span style="font-size:12px;color:#888;width:40px;text-align:left;"><%= poll.total_votes > 0 ? Math.round(opt.votes / poll.total_votes * 100) : 0 %>%</span>
      </div>
      <% }); %>
      <div style="display:flex;gap:5px;margin-top:10px;">
        <form method="POST" action="/admin/polls/toggle/<%= poll.id %>" style="display:inline;">
          <button class="btn btn-sm <%= poll.is_active ? 'btn-secondary' : 'btn-success' %>"><%= poll.is_active ? 'تعطيل' : 'تفعيل' %></button>
        </form>
        <form method="POST" action="/admin/polls/delete/<%= poll.id %>" style="display:inline;" onsubmit="return confirm('حذف الاستطلاع؟')">
          <button class="btn btn-sm btn-danger">حذف</button>
        </form>
      </div>
    </div>
    <% }); %>
    <% } else { %>
    <div class="empty-state"><p>لا توجد استطلاعات</p></div>
    <% } %>
  </div>
</div>

<%- include('footer') %>
