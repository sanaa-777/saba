<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">الاشتراك</span>
    </nav>

    <section class="page-hero">
      <span class="eyebrow">النشرة البريدية</span>
      <h1 class="page-title">اشترك لتصلك أهم الأخبار</h1>
      <p>خدمة بريدية خفيفة ومباشرة لتلقي أبرز التحديثات والعناوين العاجلة من أوتر.</p>
    </section>

    <div class="content-grid">
      <div class="content-area">
        <section class="section-block page-panel newsletter-hero">
          <div class="newsletter-copy">
            <h2>ابقَ على اطلاع دون ضوضاء</h2>
            <p>اشترك باستخدام بريدك الإلكتروني لتصلك أبرز القصص والملفات والعناوين العاجلة في تجربة منظمة.</p>
            <ul class="newsletter-benefits">
              <li>أبرز الأخبار اليومية</li>
              <li>تنبيهات بالعناوين المهمة</li>
              <li>ملفات وتحليلات مختارة</li>
            </ul>
          </div>
          <form id="subscribeForm" class="newsletter-form newsletter-form-large">
            <input type="email" name="email" placeholder="أدخل بريدك الإلكتروني" required>
            <button type="submit" class="btn btn-primary">اشترك الآن</button>
            <div id="subscribeMsg" class="newsletter-message" style="display:none;"></div>
          </form>
        </section>
      </div>
      <%- include('partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
