<%- include('partials/head') %>
<%- include('partials/header') %>
<%
  function timeAgo(dateStr) {
    if (!dateStr) return '';
    const now = new Date();
    const date = new Date(dateStr);
    const diff = Math.floor((now - date) / 1000);
    if (diff < 60) return 'الآن';
    if (diff < 3600) return 'قبل ' + Math.floor(diff / 60) + ' دقيقة';
    if (diff < 86400) return 'قبل ' + Math.floor(diff / 3600) + ' ساعة';
    if (diff < 172800) return 'قبل يوم';
    if (diff < 604800) return 'قبل ' + Math.floor(diff / 86400) + ' أيام';
    return date.toLocaleDateString('ar-YE');
  }
%>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current"><%= category.name_ar %></span>
    </nav>

    <section class="page-hero">
      <span class="eyebrow"><%= category.name_ar %></span>
      <h1 class="page-title">تغطية <%= category.name_ar %></h1>
      <p>صفحة تصنيف منظّمة بعرض تحريري واضح، مع إبراز القصة الأهم ثم قائمة الأخبار الداعمة والأرشيف الكامل.</p>
    </section>

    <div class="content-grid">
      <div class="content-area">
        <% if (news.length > 0) { %>
          <section class="section-block">
            <div class="section-header">
              <div>
                <h2>ملف اليوم</h2>
                <p><%= pagination.total %> خبر ضمن هذا التصنيف.</p>
              </div>
              <span class="news-count">الصفحة <%= pagination.page %> من <%= pagination.totalPages || 1 %></span>
            </div>

            <div class="featured-listing">
              <article class="lead-card">
                <a class="lead-card-media" href="/news/<%= news[0].id %>">
                  <% if (news[0].image) { %><img src="<%= news[0].image %>" alt="<%= news[0].title %><% } %>">
                </a>
                <div class="lead-card-body">
                  <span class="eyebrow"><%= category.name_ar %></span>
                  <h2><a href="/news/<%= news[0].id %>"><%= news[0].title %></a></h2>
                  <% if (news[0].summary) { %><p><%= news[0].summary %></p><% } %>
                  <div class="story-meta">
                    <span><%= new Date(news[0].published_at).toLocaleDateString('ar-YE') %></span>
                    <span><%= news[0].views %> مشاهدة</span>
                    <span><%= news[0].source || settings.site_name || 'أوتر نيوز' %></span>
                  </div>
                </div>
              </article>

              <div class="compact-stack">
                <% news.slice(1, 5).forEach(item => { %>
                  <article class="story-card-horizontal">
                    <a class="story-card-media" href="/news/<%= item.id %>-<%= (item.slug || item.title || "").replace(/\s+/g, "-").substring(0, 80).toLowerCase() %>">
                      <% if (item.image) { %><img src="<%= item.image %>" alt="<%= item.title %><% } %>" loading="lazy">
                    </a>
                    <div class="story-card-body">
                      <span class="eyebrow"><%= item.category_name || category.name_ar %></span>
                      <h3><a href="/news/<%= item.id %>-<%= (item.slug || item.title || "").replace(/\s+/g, "-").substring(0, 80).toLowerCase() %>"><%= item.title %></a></h3>
                      <% if (item.summary) { %><p><%= item.summary %></p><% } %>
                      <div class="story-meta">
                        <span><%= timeAgo(item.published_at) %></span>
                        <span><%= item.views %> مشاهدة</span>
                      </div>
                    </div>
                  </article>
                <% }) %>
              </div>
            </div>
          </section>

          <section class="section-block">
            <div class="section-header">
              <div>
                <h2>كل الأخبار</h2>
                <p>قائمة كاملة قابلة للتصفح مع ترتيب زمني واضح.</p>
              </div>
            </div>

            <div class="news-list">
              <% news.forEach(item => { %>
                <article class="news-list-item">
                  <div class="list-item-image">
                    <a href="/news/<%= item.id %>-<%= (item.slug || item.title || "").replace(/\s+/g, "-").substring(0, 80).toLowerCase() %>">
                      <% if (item.image) { %><img src="<%= item.image %>" alt="<%= item.title %><% } %>" loading="lazy">
                    </a>
                  </div>
                  <div class="list-item-content">
                    <span class="eyebrow"><%= item.category_name || category.name_ar %></span>
                    <h3><a href="/news/<%= item.id %>-<%= (item.slug || item.title || "").replace(/\s+/g, "-").substring(0, 80).toLowerCase() %>"><%= item.title %></a></h3>
                    <% if (item.summary) { %><p><%= item.summary %></p><% } %>
                    <div class="card-meta">
                      <span><%= timeAgo(item.published_at) %></span>
                      <span><%= item.views %> مشاهدة</span>
                    </div>
                  </div>
                </article>
              <% }) %>
            </div>

            <% if (pagination.totalPages > 1) { %>
            <div class="pagination">
              <% if (pagination.page > 1) { %>
                <a href="?page=<%= pagination.page - 1 %>" class="page-link">السابق</a>
              <% } %>
              <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                <a href="?page=<%= i %>" class="page-link <%= i === pagination.page ? 'active' : '' %>"><%= i %></a>
              <% } %>
              <% if (pagination.page < pagination.totalPages) { %>
                <a href="?page=<%= pagination.page + 1 %>" class="page-link">التالي</a>
              <% } %>
            </div>
            <% } %>
          </section>
        <% } else { %>
          <div class="no-results"><p>لا توجد أخبار في هذا التصنيف حالياً.</p></div>
        <% } %>
      </div>

      <%- include('partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
