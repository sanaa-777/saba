<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">اتصل بنا</span>
    </nav>

    <section class="page-hero">
      <span class="eyebrow">التواصل</span>
      <h1 class="page-title">تواصل مع فريق أوتر نيوز</h1>
      <p>للاستفسارات التحريرية، المقترحات، أو فرص التعاون، استخدم قنوات التواصل التالية.</p>
    </section>

    <div class="content-grid">
      <div class="content-area">
        <section class="section-block page-panel">
          <div class="info-grid">
            <div class="info-card">
              <h3>البريد الإلكتروني</h3>
              <p><a href="mailto:<%= settings.contact_email || 'info@awtarnews.com' %>"><%= settings.contact_email || 'info@awtarnews.com' %></a></p>
            </div>
            <div class="info-card">
              <h3>الهاتف</h3>
              <p dir="ltr"><%= settings.contact_phone || '+967-1-234567' %></p>
            </div>
            <div class="info-card">
              <h3>العنوان</h3>
              <p><%= settings.contact_address || 'صنعاء، الجمهورية اليمنية' %></p>
            </div>
            <div class="info-card">
              <h3>التعاون والمساهمات</h3>
              <p>نرحب بالمقترحات والمواد الصحفية والتقارير الميدانية عبر البريد الرسمي.</p>
            </div>
          </div>
          <div class="policy-note">
            <strong>متابعة المنصات:</strong>
            <span>يمكنك أيضاً متابعة أوتر نيوز عبر الروابط الاجتماعية في الشريط الجانبي والتذييل.</span>
          </div>
        </section>
      </div>
      <%- include('partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
