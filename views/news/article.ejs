<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <a href="/category/<%= article.cat_id %>"><%= article.category_name %></a>
      <span class="separator">/</span>
      <span class="current"><%= article.title.length > 70 ? article.title.substring(0, 70) + '…' : article.title %></span>
    </nav>

    <div class="content-grid">
      <div class="content-area">
        <article class="article-page">
          <header class="article-header">
            <span class="article-category"><%= article.category_name %></span>
            <h1 class="article-title"><%= article.title %></h1>
<%
  function timeAgo(dateStr) {
    if (!dateStr) return '';
    const now = new Date();
    const date = new Date(dateStr);
    const diff = Math.floor((now - date) / 1000);
    if (diff < 60) return 'الآن';
    if (diff < 3600) return 'قبل ' + Math.floor(diff / 60) + ' دقيقة';
    if (diff < 86400) return 'قبل ' + Math.floor(diff / 3600) + ' ساعة';
    if (diff < 172800) return 'قبل يوم';
    if (diff < 604800) return 'قبل ' + Math.floor(diff / 86400) + ' أيام';
    return date.toLocaleDateString('ar-YE');
  }
%>
            <div class="article-meta">
              <span>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg>
                <%= timeAgo(article.published_at) %>
              </span>
              <% if (article.source) { %>
              <span>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 0 4 24V4.5A2.5 2.5 0 0 1 6.5 2Z"></path></svg>
                <%= article.source %>
              </span>
              <% } %>
            </div>
          </header>

          <% if (article.image) { %>
          <div class="article-image">
            <img src="<%= article.image %>" alt="<%= article.title %>">
          </div>
          <% } %>

          <% if (article.summary) { %>
          <div class="article-summary">
            <p><%= article.summary %></p>
          </div>
          <% } %>

          <div class="article-content"><%- article.content %></div>

          <% if (tags && tags.length > 0) { %>
          <div class="article-tags">
            <span class="tags-label"><%= t('tags') %>:</span>
            <% tags.forEach(tag => { %>
              <a href="/tag/<%= tag.slug %>" class="tag-link">#<%= tag.name %></a>
            <% }) %>
          </div>
          <% } %>

          <div class="social-sharing">
            <span><%= t('share') %></span>
            <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent(currentPath) %>" target="_blank" rel="noopener" class="share-btn" aria-label="Facebook"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13.5 21v-8h2.7l.4-3h-3.1V8.2c0-.9.3-1.5 1.5-1.5h1.7V4c-.3 0-1.3-.1-2.5-.1-2.4 0-4 1.5-4 4.2V10H7.5v3h2.6v8h3.4z"/></svg></a>
            <a href="https://twitter.com/intent/tweet?url=<%= encodeURIComponent(currentPath) %>&text=<%= encodeURIComponent(article.title) %>" target="_blank" rel="noopener" class="share-btn" aria-label="X"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.9 2H22l-6.8 7.8L23.2 22h-6.3l-4.9-6.4L6.3 22H3.2l7.3-8.4L1 2h6.5l4.4 5.8L18.9 2zm-1.1 18h1.7L6.6 3.9H4.8L17.8 20z"/></svg></a>
            <a href="https://wa.me/?text=<%= encodeURIComponent(article.title + ' ' + currentPath) %>" target="_blank" rel="noopener" class="share-btn" aria-label="WhatsApp"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 3.5A11.9 11.9 0 0 0 12.1 0C5.5 0 .2 5.3.2 11.9c0 2.1.5 4.1 1.5 5.9L0 24l6.3-1.7a11.9 11.9 0 0 0 5.7 1.4h.1c6.6 0 11.9-5.3 11.9-11.9 0-3.2-1.2-6.2-3.5-8.3Zm-8.4 18.2h-.1a9.8 9.8 0 0 1-5-1.4l-.4-.2-3.7 1 1-3.6-.2-.4a9.9 9.9 0 0 1-1.5-5.2C2.2 6.4 6.7 2 12.1 2c2.6 0 5.1 1 7 2.9a9.7 9.7 0 0 1 2.9 7c0 5.4-4.4 9.8-9.9 9.8Zm5.4-7.3c-.3-.1-1.7-.8-2-.9-.3-.1-.5-.1-.7.1-.2.3-.8 1-1 1.2-.2.2-.4.2-.7.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.4.1-.6.1-.1.3-.3.5-.5.2-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.1-.7-1.7-1-2.3-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1.1 1-1.1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2.1-1.4.2-.7.2-1.3.2-1.4-.1-.1-.3-.2-.6-.3Z"/></svg></a>
            <a href="https://t.me/share/url?url=<%= encodeURIComponent(currentPath) %>&text=<%= encodeURIComponent(article.title) %>" target="_blank" rel="noopener" class="share-btn" aria-label="Telegram"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9.8 15.6 9.4 21c.6 0 .9-.3 1.3-.6l3-2.9 6.1 4.5c1.1.6 1.8.3 2.1-1l3.8-17.7h0c.4-1.8-.6-2.5-1.7-2.1L1.8 9.5c-1.7.7-1.7 1.7-.3 2.1l5.7 1.8L20.4 5c.6-.4 1.2-.2.7.2"/></svg></a>
            <a href="mailto:?subject=<%= encodeURIComponent(article.title) %>&body=<%= encodeURIComponent(currentPath) %>" class="share-btn" aria-label="Email"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><path d="m22 6-10 7L2 6"></path></svg></a>
            <button class="share-btn print" aria-label="Print"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9V2h12v7"></path><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><path d="M6 14h12v8H6z"></path></svg></button>
          </div>

          <section class="comments-section">
            <h3><%= t('comments') %> (<%= commentCount %>)</h3>
            <form class="comment-form" id="commentForm">
              <input type="hidden" name="news_id" value="<%= article.id %>">
              <div class="form-row">
                <div class="form-group"><input type="text" name="author_name" placeholder="<%= t('your_name') %>" required></div>
                <div class="form-group"><input type="email" name="author_email" placeholder="<%= t('email') %> (اختياري)"></div>
              </div>
              <div class="form-group"><textarea name="content" placeholder="<%= t('your_comment') %>" rows="5" required></textarea></div>
              <button type="submit" class="btn btn-primary"><%= t('submit_comment') %></button>
              <div class="comment-message" id="commentMessage" style="display:none;"></div>
            </form>

            <div class="comments-list" id="commentsList">
              <% if (comments.length > 0) { %>
                <% comments.forEach(comment => { %>
                  <div class="comment-item">
                    <div class="comment-header">
                      <span class="comment-author"><%= comment.author_name %></span>
                      <span class="comment-date"><%= timeAgo(comment.created_at) %></span>
                    </div>
                    <div class="comment-body"><p><%= comment.content %></p></div>
                  </div>
                <% }) %>
              <% } else { %>
                <p class="no-comments">لا توجد تعليقات بعد. كن أول من يعلّق.</p>
              <% } %>
            </div>
          </section>

          <div class="article-nav">
            <% if (prevArticle) { %>
            <a href="/news/<%= prevArticle.id %>" class="nav-prev">
              <span>الخبر السابق</span>
              <h4><%= prevArticle.title.length > 80 ? prevArticle.title.substring(0, 80) + '…' : prevArticle.title %></h4>
            </a>
            <% } %>
            <% if (nextArticle) { %>
            <a href="/news/<%= nextArticle.id %>" class="nav-next">
              <span>الخبر التالي</span>
              <h4><%= nextArticle.title.length > 80 ? nextArticle.title.substring(0, 80) + '…' : nextArticle.title %></h4>
            </a>
            <% } %>
          </div>

          <% if (relatedNews && relatedNews.length > 0) { %>
          <section class="related-news">
            <h3>أخبار ذات صلة</h3>
            <div class="related-grid">
              <% relatedNews.forEach(item => { %>
                <article class="related-card<%= !item.image ? ' no-image' : '' %>">
                  <% if (item.image) { %>
                  <div class="card-image">
                    <a href="/news/<%= item.id %>"><img src="<%= item.image %>" alt="<%= item.title %>" loading="lazy"></a>
                  </div>
                  <% } %>
                  <div class="card-content">
                    <span class="eyebrow"><%= item.category_name || article.category_name %></span>
                    <h4><a href="/news/<%= item.id %>"><%= item.title %></a></h4>
                    <span class="card-date"><%= timeAgo(item.published_at) %></span>
                  </div>
                </article>
              <% }) %>
            </div>
          </section>
          <% } %>
        </article>
      </div>

      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
