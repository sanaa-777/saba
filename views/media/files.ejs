<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">ملفات وتحقيقات</span>
    </nav>

    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header">
            <h2>ملفات وتحقيقات</h2>
          </div>

          <% if (typeof files !== 'undefined' && files.length > 0) { %>
          <div class="news-list">
            <% files.forEach(file => { %>
              <article class="news-list-item">
                <div class="list-item-image">
                  <img src="<%= file.thumbnail || file.file_path %>" alt="<%= file.title %>" loading="lazy">
                </div>
                <div class="list-item-content">
                  <h3><%= file.title %></h3>
                  <p><%= file.description %></p>
                  <span class="card-date"><%= new Date(file.created_at).toLocaleDateString('ar-YE') %></span>
                </div>
              </article>
            <% }); %>
          </div>
          <% } else { %>
          <div class="no-results">
            <p>لا توجد ملفات حالياً</p>
          </div>
          <% } %>
        </section>
      </div>

      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
