<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">ملفات وتحقيقات</span>
    </nav>

    <section class="page-hero">
      <span class="eyebrow">ملفات معمقة</span>
      <h1 class="page-title">ملفات وتحقيقات</h1>
      <p>مساحة تحريرية للمواد التفسيرية والملفات المتخصصة بتصميم واضح يدعم القراءة الممتدة.</p>
    </section>

    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header"><div><h2>الأرشيف المتخصص</h2><p>محتوى منظّم للقراءة والتحليل مع إبراز العناوين والوصف وتاريخ النشر.</p></div></div>
          <% if (typeof files !== 'undefined' && files.length > 0) { %>
            <div class="news-list">
              <% files.forEach(file => { %>
                <article class="news-list-item">
                  <div class="list-item-image">
                    <img src="<%= file.thumbnail || file.file_path %>" alt="<%= file.title %>" loading="lazy">
                  </div>
                  <div class="list-item-content">
                    <span class="eyebrow">ملف</span>
                    <h3><%= file.title %></h3>
                    <% if (file.description) { %><p><%= file.description %></p><% } %>
                    <span class="card-date"><%= new Date(file.created_at).toLocaleDateString('ar-YE') %></span>
                  </div>
                </article>
              <% }); %>
            </div>
          <% } else { %>
            <div class="no-results"><p>لا توجد ملفات حالياً.</p></div>
          <% } %>
        </section>
      </div>
      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
