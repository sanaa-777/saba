<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">كاريكاتير</span>
    </nav>

    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header">
            <h2>كاريكاتير</h2>
          </div>

          <% if (typeof caricatures !== 'undefined' && caricatures.length > 0) { %>
          <div class="media-grid">
            <% caricatures.forEach(item => { %>
              <div class="media-card">
                <div class="media-thumbnail">
                  <img src="<%= item.file_path %>" alt="<%= item.title %>" loading="lazy">
                </div>
                <div class="media-info">
                  <h3><%= item.title %></h3>
                  <span class="media-date"><%= new Date(item.created_at).toLocaleDateString('ar-YE') %></span>
                </div>
              </div>
            <% }); %>
          </div>
          <% } else { %>
          <div class="no-results">
            <p>لا توجد رسوم كاريكاتيرية حالياً</p>
          </div>
          <% } %>
        </section>
      </div>

      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
