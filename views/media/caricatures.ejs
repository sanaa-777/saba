<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">كاريكاتير</span>
    </nav>
    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header" style="border-color: #880e4f;">
            <h2 style="color: #880e4f;">✏️ كاريكاتير</h2>
          </div>
          <% if (typeof caricatures !== 'undefined' && caricatures.length > 0) { %>
          <div class="media-grid">
            <% caricatures.forEach(item => { %>
              <div class="media-card" onclick="openImageModal('<%= item.file_path %>', '<%= item.title %>')">
                <div class="media-card-image">
                  <img src="<%= item.file_path %>" alt="<%= item.title %>" loading="lazy">
                </div>
                <div class="media-card-body">
                  <h3><a href="javascript:void(0)"><%= item.title %></a></h3>
                  <p><%= item.description || '' %></p>
                  <span class="card-date"><%= new Date(item.created_at).toLocaleDateString('ar-YE') %></span>
                </div>
              </div>
            <% }); %>
          </div>
          <% } else { %>
          <div class="no-results"><p>لا توجد كاريكاتير حالياً</p></div>
          <% } %>
        </section>
      </div>
      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
