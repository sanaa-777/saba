<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">معرض الصور</span>
    </nav>

    <section class="page-hero">
      <span class="eyebrow">محتوى بصري</span>
      <h1 class="page-title">معرض الصور</h1>
      <p>لقطات وصور خبرية ضمن شبكة بصرية نظيفة تدعم القراءة السريعة على الهاتف وسطح المكتب.</p>
    </section>

    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header"><div><h2>أحدث الصور</h2><p>تجربة عرض بصري محسنة مع تكبير مباشر.</p></div></div>
          <% if (galleries.length > 0) { %>
            <div class="media-grid">
              <% galleries.forEach(gallery => { %>
                <article class="media-card" onclick="openImageModal('<%= gallery.file_path %>', '<%= gallery.title %>')">
                  <div class="media-card-image">
                    <img src="<%= gallery.file_path %>" alt="<%= gallery.title %>" loading="lazy">
                  </div>
                  <div class="media-card-body">
                    <span class="eyebrow">صورة</span>
                    <h3><a href="javascript:void(0)"><%= gallery.title %></a></h3>
                    <% if (gallery.description) { %><p><%= gallery.description %></p><% } %>
                    <span class="card-date"><%= new Date(gallery.created_at).toLocaleDateString('ar-YE') %></span>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="no-results"><p>لا توجد صور حالياً.</p></div>
          <% } %>
        </section>
      </div>
      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
