<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">معرض الصور</span>
    </nav>

    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header">
            <h2>معرض الصور</h2>
          </div>

          <% if (galleries.length > 0) { %>
          <div class="media-grid galleries-page-grid">
            <% galleries.forEach(gallery => { %>
              <a href="/gallery/<%= gallery.id %>" class="gallery-card">
                <div class="gallery-thumbnail">
                  <img src="<%= gallery.thumbnail || gallery.file_path %>" alt="<%= gallery.title %>" loading="lazy">
                  <div class="gallery-overlay">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="white"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/></svg>
                  </div>
                </div>
                <h3><%= gallery.title %></h3>
                <span class="media-date"><%= new Date(gallery.created_at).toLocaleDateString('ar-YE') %></span>
              </a>
            <% }); %>
          </div>
          <% } else { %>
          <div class="no-results">
            <p>لا توجد معارض صور حالياً</p>
          </div>
          <% } %>
        </section>
      </div>

      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
