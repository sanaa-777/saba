<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">إصداراتنا</span>
    </nav>

    <section class="page-hero">
      <span class="eyebrow">أرشيف التحرير</span>
      <h1 class="page-title">إصدارات أوتر نيوز</h1>
      <p>صفحة مرجعية تجمع المنشورات والإصدارات ضمن واجهة واضحة قابلة للتصفح والقراءة.</p>
    </section>

    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header"><div><h2>أحدث الإصدارات</h2><p>منشورات وأعداد مرئية ضمن عرض أنيق سريع.</p></div></div>
          <% if (typeof publications !== 'undefined' && publications.length > 0) { %>
            <div class="media-grid">
              <% publications.forEach(item => { %>
                <article class="media-card" onclick="openImageModal('<%= item.file_path %>', '<%= item.title %>')">
                  <div class="media-card-image">
                    <img src="<%= item.file_path %>" alt="<%= item.title %>" loading="lazy">
                  </div>
                  <div class="media-card-body">
                    <span class="eyebrow">إصدار</span>
                    <h3><a href="javascript:void(0)"><%= item.title %></a></h3>
                    <% if (item.description) { %><p><%= item.description %></p><% } %>
                    <span class="card-date"><%= new Date(item.created_at).toLocaleDateString('ar-YE') %></span>
                  </div>
                </article>
              <% }); %>
            </div>
          <% } else { %>
            <div class="no-results"><p>لا توجد إصدارات حالياً.</p></div>
          <% } %>
        </section>
      </div>
      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
