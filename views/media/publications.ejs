<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">المنشورات</span>
    </nav>

    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header">
            <h2>المنشورات</h2>
          </div>

          <% if (typeof publications !== 'undefined' && publications.length > 0) { %>
          <div class="media-grid">
            <% publications.forEach(pub => { %>
              <div class="media-card publication-card">
                <div class="media-thumbnail">
                  <img src="<%= pub.thumbnail || pub.file_path %>" alt="<%= pub.title %>" loading="lazy">
                </div>
                <div class="media-info">
                  <h3><%= pub.title %></h3>
                  <p><%= pub.description %></p>
                  <span class="media-date"><%= new Date(pub.created_at).toLocaleDateString('ar-YE') %></span>
                </div>
              </div>
            <% }); %>
          </div>
          <% } else { %>
          <div class="no-results">
            <p>لا توجد منشورات حالياً</p>
          </div>
          <% } %>
        </section>
      </div>

      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
