<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">المكتبة الصوتية</span>
    </nav>

    <section class="page-hero">
      <span class="eyebrow">وسائط صوتية</span>
      <h1 class="page-title">المكتبة الصوتية</h1>
      <p>تسجيلات وتقارير صوتية ضمن بطاقات واضحة بمشغّل مدمج وتجربة استماع مريحة.</p>
    </section>

    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header"><div><h2>أحدث التسجيلات</h2><p>تشغيل مباشر وسريع مع وصف مختصر لكل مادة.</p></div></div>
          <% if (audios.length > 0) { %>
            <div class="audios-list">
              <% audios.forEach(audio => { %>
                <article class="audio-card">
                  <div class="audio-icon">
                    <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>
                  </div>
                  <div class="audio-info">
                    <span class="eyebrow">صوت</span>
                    <h4><%= audio.title %></h4>
                    <% if (audio.description) { %><p><%= audio.description %></p><% } %>
                    <span class="card-date"><%= new Date(audio.created_at).toLocaleDateString('ar-YE') %></span>
                  </div>
                  <div class="audio-player-wrap">
                    <audio controls>
                      <source src="<%= audio.file_path %>" type="audio/mpeg">
                      المتصفح لا يدعم تشغيل الصوت
                    </audio>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="no-results"><p>لا توجد ملفات صوتية حالياً.</p></div>
          <% } %>
        </section>
      </div>
      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
