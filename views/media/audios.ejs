<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">المكتبة الصوتية</span>
    </nav>
    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header section-header-audio">
            <h2>🎙️ مكتبة الصوت</h2>
          </div>
          <% if (audios.length > 0) { %>
          <div class="audios-list">
            <% audios.forEach(audio => { %>
              <div class="audio-card">
                <div class="audio-icon">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="#1a237e"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>
                </div>
                <div class="audio-info">
                  <h4><%= audio.title %></h4>
                  <p><%= audio.description || '' %></p>
                  <span class="card-date"><%= new Date(audio.created_at).toLocaleDateString('ar-YE') %></span>
                </div>
                <div class="audio-player" style="margin-top:10px;">
                  <audio controls style="width:100%;height:36px;">
                    <source src="<%= audio.file_path %>" type="audio/mpeg">
                    المتصفح لا يدعم تشغيل الصوت
                  </audio>
                </div>
              </div>
            <% }); %>
          </div>
          <% } else { %>
          <div class="no-results"><p>لا توجد ملفات صوتية حالياً</p></div>
          <% } %>
        </section>
      </div>
      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
