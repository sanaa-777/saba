<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">المكتبة الصوتية</span>
    </nav>

    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header">
            <h2>المكتبة الصوتية</h2>
          </div>

          <% if (audios.length > 0) { %>
          <div class="audios-page-list">
            <% audios.forEach(audio => { %>
              <div class="audio-item">
                <div class="audio-icon">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="#1a237e"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>
                </div>
                <div class="audio-details">
                  <h3><%= audio.title %></h3>
                  <p><%= audio.description %></p>
                  <span class="audio-date"><%= new Date(audio.created_at).toLocaleDateString('ar-YE') %></span>
                </div>
                <audio controls preload="none">
                  <source src="<%= audio.file_path %>" type="audio/mpeg">
                  المتصفح لا يدعم تشغيل الملفات الصوتية
                </audio>
              </div>
            <% }); %>
          </div>
          <% } else { %>
          <div class="no-results">
            <p>لا توجد ملفات صوتية حالياً</p>
          </div>
          <% } %>
        </section>
      </div>

      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
