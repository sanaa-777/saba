<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">الفيديوهات</span>
    </nav>

    <section class="page-hero">
      <span class="eyebrow">وسائط مرئية</span>
      <h1 class="page-title">مكتبة الفيديو</h1>
      <p>تقارير ومقاطع مرئية منظمة في واجهة تحريرية واضحة مع تشغيل سريع وتجربة عرض نظيفة.</p>
    </section>

    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header"><div><h2>أحدث المقاطع</h2><p>تصفح المحتوى المرئي المنشور حديثاً.</p></div></div>
          <% if (videos.length > 0) { %>
            <div class="media-grid">
              <% videos.forEach(video => { %>
                <article class="media-card video-card" onclick="openVideoModal('<%= video.file_path %>', '<%= video.title %>')">
                  <div class="media-card-image video-thumb">
                    <img src="<%= video.thumbnail || video.file_path %>" alt="<%= video.title %>" loading="lazy">
                    <span class="media-play-badge">
                      <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                    </span>
                  </div>
                  <div class="media-card-body">
                    <span class="eyebrow">فيديو</span>
                    <h3><a href="javascript:void(0)"><%= video.title %></a></h3>
                    <% if (video.description) { %><p><%= video.description %></p><% } %>
                    <span class="card-date"><%= new Date(video.created_at).toLocaleDateString('ar-YE') %></span>
                  </div>
                </article>
              <% }) %>
            </div>
          <% } else { %>
            <div class="no-results"><p>لا توجد فيديوهات حالياً.</p></div>
          <% } %>
        </section>
      </div>
      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
