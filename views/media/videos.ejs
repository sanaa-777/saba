<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">الفيديوهات</span>
    </nav>

    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header">
            <h2>الفيديوهات</h2>
          </div>

          <% if (videos.length > 0) { %>
          <div class="media-grid">
            <% videos.forEach(video => { %>
              <div class="media-card video-card">
                <div class="media-thumbnail">
                  <img src="<%= video.thumbnail || video.file_path %>" alt="<%= video.title %>" loading="lazy">
                  <div class="play-button">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
                <div class="media-info">
                  <h3><%= video.title %></h3>
                  <p><%= video.description %></p>
                  <span class="media-date"><%= new Date(video.created_at).toLocaleDateString('ar-YE') %></span>
                </div>
              </div>
            <% }); %>
          </div>
          <% } else { %>
          <div class="no-results">
            <p>لا توجد فيديوهات حالياً</p>
          </div>
          <% } %>
        </section>
      </div>

      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('../partials/footer') %>
