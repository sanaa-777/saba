<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">الفيديوهات</span>
    </nav>
    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header section-header-video">
            <h2>🎬 مكتبة الفيديو</h2>
          </div>
          <% if (videos.length > 0) { %>
          <div class="media-grid">
            <% videos.forEach(video => { %>
              <div class="media-card video-card" onclick="openVideoModal('<%= video.file_path %>', '<%= video.title %>')">
                <div class="media-card-image" style="position:relative;">
                  <img src="<%= video.thumbnail || video.file_path %>" alt="<%= video.title %>" loading="lazy">
                  <div class="play-button" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:60px;height:60px;background:rgba(0,0,0,0.6);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;">
                    <svg width="30" height="30" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
                <div class="media-card-body">
                  <h3><a href="javascript:void(0)"><%= video.title %></a></h3>
                  <p><%= video.description || '' %></p>
                  <span class="card-date"><%= new Date(video.created_at).toLocaleDateString('ar-YE') %></span>
                </div>
              </div>
            <% }); %>
          </div>
          <% } else { %>
          <div class="no-results"><p>لا توجد فيديوهات حالياً</p></div>
          <% } %>
        </section>
      </div>
      <%- include('../partials/sidebar') %>
    </div>
  </div>
</main>

<!-- Video Modal -->
<div id="videoModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.9);z-index:10000;align-items:center;justify-content:center;">
  <div style="position:relative;width:90%;max-width:900px;">
    <button onclick="closeVideoModal()" style="position:absolute;top:-40px;left:0;background:none;border:none;color:#fff;font-size:30px;cursor:pointer;">✕</button>
    <video id="videoPlayer" controls style="width:100%;border-radius:12px;">
      <source src="" type="video/mp4">
      المتصفح لا يدعم تشغيل الفيديو
    </video>
    <h3 id="videoTitle" style="color:#fff;text-align:center;margin-top:10px;font-family:'Tajawal',sans-serif;"></h3>
  </div>
</div>

<script>
function openVideoModal(src, title) {
  const modal = document.getElementById('videoModal');
  const player = document.getElementById('videoPlayer');
  const titleEl = document.getElementById('videoTitle');
  player.querySelector('source').src = src;
  player.load();
  titleEl.textContent = title;
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}
function closeVideoModal() {
  const modal = document.getElementById('videoModal');
  const player = document.getElementById('videoPlayer');
  player.pause();
  modal.style.display = 'none';
  document.body.style.overflow = '';
}
document.getElementById('videoModal').addEventListener('click', function(e) {
  if (e.target === this) closeVideoModal();
});
</script>

<%- include('../partials/footer') %>
