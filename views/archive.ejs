<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">أرشيف <%= date %></span>
    </nav>
    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header">
            <h2>أرشيف <%= date %></h2>
            <span class="news-count"><%= news.length %> خبر</span>
          </div>
          <% if (news.length > 0) { %>
          <div class="news-list">
            <% news.forEach(item => { %>
              <article class="news-list-item">
                <div class="list-item-image"><a href="/news/<%= item.id %>"><img src="<%= item.image || '/images/placeholder.jpg' %>" alt="<%= item.title %>" loading="lazy"></a></div>
                <div class="list-item-content">
                  <h3><a href="/news/<%= item.id %>"><%= item.title %></a></h3>
                  <p><%= item.summary %></p>
                  <div class="card-meta">
                    <span class="card-category"><%= item.category_name %></span>
                    <span class="card-date"><%= new Date(item.published_at).toLocaleDateString('ar-YE') %></span>
                  </div>
                </div>
              </article>
            <% }); %>
          </div>
          <% } else { %>
          <div class="no-results"><p>لا توجد أخبار في هذا التاريخ</p></div>
          <% } %>
        </section>
      </div>
      <%- include('partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
