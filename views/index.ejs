<%- include('partials/head') %>
<%- include('partials/header') %>

<!-- Breaking News Ticker -->
<% if (typeof breakingNews !== 'undefined' && breakingNews.length > 0) { %>
<div class="breaking-ticker">
  <span class="ticker-label">⚡ عاجل</span>
  <div class="ticker-scroll">
    <% breakingNews.forEach(item => { %>
      <a href="<%= item.link || '#' %>"><%= item.text %></a>
    <% }); %>
  </div>
</div>
<% } %>

<main class="home-page">
  <div class="container">

    <!-- ===== HERO SECTION ===== -->
    <% if (typeof sliderItems !== 'undefined' && sliderItems.length > 0) { %>
    <section class="hero-block">
      <!-- Main Story -->
      <div class="hero-main">
        <a href="/news/<%= sliderItems[0].news_id %>">
          <img src="<%= sliderItems[0].image || '/images/placeholder.jpg' %>" alt="<%= sliderItems[0].title %>">
          <div class="hero-overlay">
            <h2><%= sliderItems[0].title %></h2>
            <p><%= sliderItems[0].summary %></p>
          </div>
        </a>
      </div>
      <!-- Side Stories -->
      <div class="hero-side">
        <% sliderItems.slice(1, 5).forEach(item => { %>
        <a href="/news/<%= item.news_id %>" class="hero-side-item">
          <img src="<%= item.image || '/images/placeholder.jpg' %>" alt="<%= item.title %>">
          <h3><%= item.title %></h3>
        </a>
        <% }); %>
      </div>
    </section>
    <% } %>

    <!-- ===== LATEST NEWS (horizontal scroll on mobile) ===== -->
    <% if (typeof latestNews !== 'undefined' && latestNews.length > 0) { %>
    <section class="latest-section">
      <div class="section-title">
        <h2>آخر الأخبار</h2>
      </div>
      <div class="latest-scroll">
        <% latestNews.slice(0, 10).forEach(item => { %>
        <a href="/news/<%= item.id %>" class="latest-card">
          <img src="<%= item.image || '/images/placeholder.jpg' %>" alt="<%= item.title %>" loading="lazy">
          <div class="latest-card-body">
            <span class="cat-badge"><%= item.category_name || 'عام' %></span>
            <h4><%= item.title %></h4>
            <span class="meta"><%= new Date(item.published_at).toLocaleDateString('ar-YE') %></span>
          </div>
        </a>
        <% }); %>
      </div>
    </section>
    <% } %>

    <!-- ===== CATEGORY SECTIONS (like saba.ye) ===== -->
    <% if (typeof categoryNews !== 'undefined' && typeof categories !== 'undefined') { %>
      <% categories.forEach(cat => { %>
        <% if (categoryNews[cat.id] && categoryNews[cat.id].length > 0) { %>
        <section class="cat-section">
          <div class="cat-header">
            <h2><a href="/category/<%= cat.id %>"><%= cat.name_ar %></a></h2>
          </div>
          <div class="cat-list">
            <% categoryNews[cat.id].slice(0, 4).forEach(item => { %>
            <a href="/news/<%= item.id %>" class="cat-item">
              <% if (item.image) { %>
              <img src="<%= item.image %>" alt="<%= item.title %>" loading="lazy">
              <% } %>
              <div class="cat-item-text">
                <h3><%= item.title %></h3>
                <span class="meta"><%= new Date(item.published_at).toLocaleDateString('ar-YE') %></span>
              </div>
            </a>
            <% }); %>
          </div>
        </section>
        <% } %>
      <% }); %>
    <% } %>

    <!-- ===== MEDIA SECTIONS ===== -->
    <% if (typeof videos !== 'undefined' && videos.length > 0) { %>
    <section class="media-section">
      <div class="cat-header">
        <h2><a href="/videos">مكتبة الفيديو</a></h2>
      </div>
      <div class="media-row">
        <% videos.slice(0, 3).forEach(item => { %>
        <a href="/videos" class="media-card" onclick="event.preventDefault();openVideoModal('<%= item.file_path %>','<%= item.title %>')">
          <img src="<%= item.thumbnail || item.file_path %>" alt="<%= item.title %>" loading="lazy">
          <span class="play-btn">▶</span>
          <p><%= item.title %></p>
        </a>
        <% }); %>
      </div>
    </section>
    <% } %>

    <% if (typeof galleries !== 'undefined' && galleries.length > 0) { %>
    <section class="media-section">
      <div class="cat-header">
        <h2><a href="/galleries">معرض الصور</a></h2>
      </div>
      <div class="media-row">
        <% galleries.slice(0, 4).forEach(item => { %>
        <a href="/gallery/<%= item.id %>" class="media-card">
          <img src="<%= item.thumbnail || item.file_path %>" alt="<%= item.title %>" loading="lazy">
          <p><%= item.title %></p>
        </a>
        <% }); %>
      </div>
    </section>
    <% } %>

    <% if (typeof audios !== 'undefined' && audios.length > 0) { %>
    <section class="media-section">
      <div class="cat-header">
        <h2><a href="/audios">مكتبة الصوت</a></h2>
      </div>
      <div class="media-row">
        <% audios.slice(0, 3).forEach(item => { %>
        <div class="audio-card">
          <p><%= item.title %></p>
          <audio controls preload="none"><source src="<%= item.file_path %>"></audio>
        </div>
        <% }); %>
      </div>
    </section>
    <% } %>

  </div>
</main>

<%- include('partials/footer') %>
