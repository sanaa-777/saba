<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="home-page">
  <div class="container">
    <% const lead = sliderItems && sliderItems.length ? sliderItems[0] : (featuredNews && featuredNews.length ? featuredNews[0] : latestNews[0]); %>
    <% const secondaryStories = sliderItems && sliderItems.length > 1 ? sliderItems.slice(1, 5) : latestNews.slice(1, 5); %>

    <% if (lead) { %>
    <section class="home-top-grid">
      <div class="hero-cluster">
        <article class="hero-primary">
          <a href="/news/<%= lead.news_id || lead.id %>">
            <div class="hero-primary-media">
              <img src="<%= lead.image || '/images/placeholder.jpg' %>" alt="<%= lead.title || lead.news_title %>">
              <div class="hero-primary-overlay">
                <span class="eyebrow accent"><%= (lead.category_name || 'الواجهة الرئيسية') %></span>
                <h2><%= lead.title || lead.news_title %></h2>
                <% if (lead.summary) { %><p><%= lead.summary %></p><% } %>
                <div class="story-meta inverse">
                  <span><%= new Date((lead.published_at || Date.now())).toLocaleDateString('ar-YE') %></span>
                  <span><%= lead.source || settings.site_name || 'أوتر' %></span>
                </div>
              </div>
            </div>
          </a>
        </article>

        <div class="hero-secondary-list">
          <% secondaryStories.forEach(item => { %>
            <article class="hero-secondary-card">
              <a class="hero-secondary-card-media" href="/news/<%= item.news_id || item.id %>">
                <img src="<%= item.image || '/images/placeholder.jpg' %>" alt="<%= item.title || item.news_title %>" loading="lazy">
              </a>
              <div class="hero-secondary-card-content">
                <span class="eyebrow"><%= item.category_name || 'أخبار' %></span>
                <h3><a href="/news/<%= item.news_id || item.id %>"><%= item.title || item.news_title %></a></h3>
                <div class="story-meta">
                  <span><%= new Date((item.published_at || Date.now())).toLocaleDateString('ar-YE') %></span>
                </div>
              </div>
            </article>
          <% }) %>
        </div>
      </div>

      <aside class="latest-rail">
        <div class="latest-rail-header">
          <div>
            <h3>غرفة الأخبار</h3>
            <p>تحديثات سريعة مرتبة حسب التوقيت والأهمية.</p>
          </div>
          <span class="live-dot"></span>
        </div>
        <div class="latest-feed">
          <% latestNews.slice(0, 8).forEach((item, index) => { %>
            <article class="latest-feed-item">
              <div class="latest-feed-index"><%= index + 1 %></div>
              <div>
                <span class="eyebrow <%= item.is_breaking ? 'accent' : '' %>"><%= item.category_name || 'عام' %></span>
                <h4><a href="/news/<%= item.id %>"><%= item.title %></a></h4>
                <div class="story-meta">
                  <span><%= new Date(item.published_at).toLocaleDateString('ar-YE') %></span>
                  <span><%= item.source || settings.site_name || 'أوتر' %></span>
                </div>
              </div>
            </article>
          <% }) %>
        </div>
      </aside>
    </section>
    <% if (sidebarAds && sidebarAds.length > 0) { const ad = sidebarAds[0]; %>
    <section class="home-ad-block sidebar-ad">
      <% if (ad.code) { %>
        <div class="home-ad-inner"><%- ad.code %></div>
      <% } else { %>
        <a class="home-ad-inner" href="<%= ad.link || '#' %>" <%= ad.link ? 'target="_blank" rel="noopener noreferrer"' : '' %>>
          <% if (ad.image) { %><img src="<%= ad.image %>" alt="<%= ad.name %>" loading="lazy"><% } %>
          <div class="home-ad-caption"><span>إعلان جانبي</span><strong><%= ad.name %></strong></div>
        </a>
      <% } %>
    </section>
    <% } %>
    <% } %>

    <% if (headerAds && headerAds.length > 0) { const ad = headerAds[0]; %>
    <section class="home-ad-block">
      <% if (ad.code) { %>
        <div class="home-ad-inner"><%- ad.code %></div>
      <% } else { %>
        <a class="home-ad-inner" href="<%= ad.link || '#' %>" <%= ad.link ? 'target="_blank" rel="noopener noreferrer"' : '' %>>
          <% if (ad.image) { %><img src="<%= ad.image %>" alt="<%= ad.name %>" loading="lazy"><% } %>
          <div class="home-ad-caption"><span>إعلان</span><strong><%= ad.name %></strong></div>
        </a>
      <% } %>
    </section>
    <% } %>

    <% if (featuredNews && featuredNews.length > 0) { %>
    <section class="section-block">
      <div class="section-header">
        <div>
          <h2>قصص مختارة</h2>
          <p>مجموعة تحريرية مختارة من أبرز العناوين ذات الأولوية.</p>
        </div>
      </div>
      <div class="home-featured-strip">
        <% featuredNews.slice(0, 4).forEach(item => { %>
          <article class="story-card<%= !item.image ? ' no-image' : '' %>">
            <% if (item.image) { %>
            <a class="story-card-media" href="/news/<%= item.id %>">
              <img src="<%= item.image %>" alt="<%= item.title %>" loading="lazy">
            </a>
            <% } %>
            <div class="story-card-body">
              <span class="eyebrow"><%= item.category_name || 'عام' %></span>
              <h3><a href="/news/<%= item.id %>"><%= item.title %></a></h3>
              <% if (item.summary) { %><p><%= item.summary %></p><% } %>
              <div class="story-meta">
                <span><%= new Date(item.published_at).toLocaleDateString('ar-YE') %></span>
                <span><%= item.source || settings.site_name || 'أوتر' %></span>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
    <% } %>

    <% if (latestNews && latestNews.length > 0) { %>
    <section class="section-block">
      <div class="section-header">
        <div>
          <h2>آخر الأخبار</h2>
          <p>بطاقات سريعة للمتابعة السلسة عبر الهاتف وسطح المكتب.</p>
        </div>
        <a href="/search" class="section-link">تصفح الأرشيف</a>
      </div>
      <div class="latest-scroll">
        <% latestNews.slice(0, 8).forEach(item => { %>
          <article class="latest-card<%= !item.image ? ' no-image' : '' %>">
            <% if (item.image) { %><a href="/news/<%= item.id %>"><img src="<%= item.image %>" alt="<%= item.title %>" loading="lazy"></a><% } %>
            <div class="latest-card-body">
              <span class="cat-badge"><%= item.category_name || 'عام' %></span>
              <h4><a href="/news/<%= item.id %>"><%= item.title %></a></h4>
              <div class="story-meta">
                <span><%= new Date(item.published_at).toLocaleDateString('ar-YE') %></span>
                <span><%= item.source || settings.site_name || 'أوتر' %></span>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
    <% } %>

    <% if (contentAds && contentAds.length > 0) { const ad = contentAds[0]; %>
    <section class="home-ad-block content-ad">
      <% if (ad.code) { %>
        <div class="home-ad-inner"><%- ad.code %></div>
      <% } else { %>
        <a class="home-ad-inner" href="<%= ad.link || '#' %>" <%= ad.link ? 'target="_blank" rel="noopener noreferrer"' : '' %>>
          <% if (ad.image) { %><img src="<%= ad.image %>" alt="<%= ad.name %>" loading="lazy"><% } %>
          <div class="home-ad-caption"><span>إعلان</span><strong><%= ad.name %></strong></div>
        </a>
      <% } %>
    </section>
    <% } %>

    <% if (categories && categoryNews) { %>
      <% categories.forEach(cat => { %>
        <% const items = categoryNews[cat.id] || []; %>
        <% if (items.length > 0) { %>
          <section class="section-block">
            <div class="section-header">
              <div>
                <h2><a href="/category/<%= cat.id %>"><%= cat.name_ar %></a></h2>
                <p>متابعة مركزة لملف <%= cat.name_ar %> بعناوين أساسية وداعمة.</p>
              </div>
              <a href="/category/<%= cat.id %>" class="section-link">المزيد</a>
            </div>
            <div class="category-module">
              <article class="story-card<%= !items[0].image ? ' no-image' : '' %>">
                <% if (items[0].image) { %>
                <a class="story-card-media" href="/news/<%= items[0].id %>">
                  <img src="<%= items[0].image %>" alt="<%= items[0].title %>" loading="lazy">
                </a>
                <% } %>
                <div class="story-card-body">
                  <span class="eyebrow"><%= cat.name_ar %></span>
                  <h3><a href="/news/<%= items[0].id %>"><%= items[0].title %></a></h3>
                  <% if (items[0].summary) { %><p><%= items[0].summary %></p><% } %>
                  <div class="story-meta">
                    <span><%= new Date(items[0].published_at).toLocaleDateString('ar-YE') %></span>
                    <span><%= items[0].source || settings.site_name || 'أوتر' %></span>
                  </div>
                </div>
              </article>
              <div class="story-stack">
                <% items.slice(1, 5).forEach(item => { %>
                  <article class="story-card-horizontal<%= !item.image ? ' no-image' : '' %>">
                    <% if (item.image) { %>
                    <a class="story-card-media" href="/news/<%= item.id %>">
                      <img src="<%= item.image %>" alt="<%= item.title %>" loading="lazy">
                    </a>
                    <% } %>
                    <div class="story-card-body">
                      <span class="eyebrow"><%= item.category_name || cat.name_ar %></span>
                      <h3><a href="/news/<%= item.id %>"><%= item.title %></a></h3>
                      <div class="story-meta">
                        <span><%= new Date(item.published_at).toLocaleDateString('ar-YE') %></span>
                      </div>
                    </div>
                  </article>
                <% }) %>
              </div>
            </div>
          </section>
        <% } %>
      <% }) %>
    <% } %>

    <% if ((videos && videos.length) || (galleries && galleries.length) || (publications && publications.length)) { %>
    <section class="section-block">
      <div class="section-header">
        <div>
          <h2>وسائط ومكتبات</h2>
          <p>فيديو وصور ومنشورات بتنسيق عرض غني ومرن.</p>
        </div>
      </div>
      <div class="media-strip">
        <% (videos || []).slice(0, 2).forEach(item => { %>
          <article class="media-card video-card" onclick="openVideoModal('<%= item.file_path %>', '<%= item.title %>')">
            <div class="media-card-media">
              <img src="<%= item.thumbnail || item.file_path %>" alt="<%= item.title %>" loading="lazy">
              <span class="play-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </span>
            </div>
            <div class="media-card-body">
              <span class="eyebrow">فيديو</span>
              <h3><%= item.title %></h3>
              <div class="story-meta"><span><%= new Date(item.created_at).toLocaleDateString('ar-YE') %></span></div>
            </div>
          </article>
        <% }) %>

        <% (galleries || []).slice(0, 1).forEach(item => { %>
          <article class="media-card">
            <a class="media-card-media" href="/gallery/<%= item.id %>">
              <img src="<%= item.thumbnail || item.file_path %>" alt="<%= item.title %>" loading="lazy">
            </a>
            <div class="media-card-body">
              <span class="eyebrow">صور</span>
              <h3><a href="/gallery/<%= item.id %>"><%= item.title %></a></h3>
              <div class="story-meta"><span><%= new Date(item.created_at).toLocaleDateString('ar-YE') %></span></div>
            </div>
          </article>
        <% }) %>

        <% (publications || []).slice(0, 1).forEach(item => { %>
          <article class="media-card">
            <a class="media-card-media" href="/publications">
              <img src="<%= item.thumbnail || item.file_path %>" alt="<%= item.title %>" loading="lazy">
            </a>
            <div class="media-card-body">
              <span class="eyebrow">منشور</span>
              <h3><a href="/publications"><%= item.title %></a></h3>
              <div class="story-meta"><span><%= new Date(item.created_at).toLocaleDateString('ar-YE') %></span></div>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
    <% } %>

    <% if (footerAds && footerAds.length > 0) { const ad = footerAds[0]; %>
    <section class="home-ad-block footer-ad">
      <% if (ad.code) { %>
        <div class="home-ad-inner"><%- ad.code %></div>
      <% } else { %>
        <a class="home-ad-inner" href="<%= ad.link || '#' %>" <%= ad.link ? 'target="_blank" rel="noopener noreferrer"' : '' %>>
          <% if (ad.image) { %><img src="<%= ad.image %>" alt="<%= ad.name %>" loading="lazy"><% } %>
          <div class="home-ad-caption"><span>إعلان</span><strong><%= ad.name %></strong></div>
        </a>
      <% } %>
    </section>
    <% } %>

  </div>
</main>

<%- include('partials/footer') %>
