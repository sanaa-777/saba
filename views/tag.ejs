<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="main-content">
  <div class="container">
    <nav class="breadcrumbs">
      <a href="/">الرئيسية</a>
      <span class="separator">/</span>
      <span class="current">#<%= tag.name %></span>
    </nav>
    <div class="content-grid">
      <div class="content-area">
        <section class="section-block">
          <div class="section-header">
            <h2>الوسم: #<%= tag.name %></h2>
            <span class="news-count"><%= pagination.total %> خبر</span>
          </div>
          <% if (news.length > 0) { %>
          <div class="news-list">
            <% news.forEach(item => { %>
              <article class="news-list-item">
                <div class="list-item-image"><a href="/news/<%= item.id %>"><img src="<%= item.image || '/images/placeholder.jpg' %>" alt="<%= item.title %>" loading="lazy"></a></div>
                <div class="list-item-content">
                  <h3><a href="/news/<%= item.id %>"><%= item.title %></a></h3>
                  <p><%= item.summary %></p>
                  <div class="card-meta">
                    <span class="card-category"><%= item.category_name %></span>
                    <span class="card-date"><%= new Date(item.published_at).toLocaleDateString('ar-YE') %></span>
                  </div>
                </div>
              </article>
            <% }); %>
          </div>
          <% if (pagination.totalPages > 1) { %>
          <div class="pagination">
            <% for (let i = 1; i <= pagination.totalPages; i++) { %>
              <a href="?page=<%= i %>" class="page-link <%= i === pagination.page ? 'active' : '' %>"><%= i %></a>
            <% } %>
          </div>
          <% } %>
          <% } else { %>
          <div class="no-results"><p>لا توجد أخبار بهذا الوسم</p></div>
          <% } %>
        </section>
      </div>
      <%- include('partials/sidebar') %>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
